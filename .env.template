# ==============================================================================
# Claude Trading Skills - Environment Variables Template
# ==============================================================================
# Copy this file to '.env' and fill in your keys.
# Do NOT commit your actual '.env' file containing keys to git or public repos.
# ==============================================================================

# 1. Financial Modeling Prep (FMP) API Key
# Required for CANSLIM Screener, Earnings Trade Analyzer, Value Dividend Screener, etc.
# Get a free/paid key from: https://site.financialmodelingprep.com/developer/docs
FMP_API_KEY=your_fmp_api_key_here

# 2. FINVIZ Elite API Key (Optional)
# Optional but recommended to speed up dividend growth and pullback screeners.
# Get key from: https://elite.finviz.com/
FINVIZ_API_KEY=your_finviz_api_key_here

# 3. Alpaca Trading API Configuration
# Required for Portfolio Manager operations.
# You can use a free Paper Trading account.
# Get credentials from: https://alpaca.markets/
ALPACA_API_KEY=your_alpaca_api_key_id_here
ALPACA_SECRET_KEY=your_alpaca_secret_key_here
ALPACA_PAPER=true

# 4. Optional UI/Subprocess Configurations
# Set to 1 to enable full UTF-8 logs and outputs in some environments
PYTHONIOENCODING=utf-8
PYTHONUTF8=1

# 5. Gemini API Key (For Skill Improvement Loop)
# Required for running the skill improvement pipeline.
# Get key from: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-3.1-flash
